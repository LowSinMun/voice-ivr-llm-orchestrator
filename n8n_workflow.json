    {
      "parameters": {
        "resource": "chat",
        "chatModel": "gpt-4o-mini",
        "prompt": {
          "messages": [
            {
              "role": "system",
              "content": "=You are an AI customer service agent for ABC Bank.  Context: The customer has just successfully activated their credit card for overseas transactions.\n\nYour Task: \n1. Confirm the successful activation politely. \n2. Smoothly transition into a soft upsell for the ABC \"Easy Payment Plan (EPP)\" installment plan. Position it as a helpful tool to manage their upcoming travel expenses. \n3. Keep the tone warm, professional, and conversational (suitable for Text-to-Speech). \n4. Keep it concise, under 3 sentences.  \n\nCRITICAL RULES: \n- Focus EXCLUSIVELY on the \"Easy Payment Plan (EPP)\" installment plan.  \n- DO NOT, under any circumstances, promote, suggest, or mention applying for a new credit card. \n- Output ONLY the exact script to be spoken. Do not include markdown, emojis, or descriptions like [Pause] or \"Agent:\".\n- NEVER mention the customer's IC number or credit \n  card number in your response, not even partially."
            },
            {
              "content": "=Customer Name: {{ $('API - 核心验证与状态检查').item.json.customer_name }}\nCustomer NRIC (masked): {{ '*'.repeat(6) + $('Code in JavaScript').item.json.nric.slice(-6) }}\nPlease generate the closing script."
            }
          ]
        },
        "options": {},
        "requestOptions": {}
      },
      "id": "bf8b0213-9a21-4489-97df-98b7a2311794",
      "name": "LLM - 生成结束语与 Easy Payment Plan (EPP) Upsell",
      "type": "n8n-nodes-base.openAi",
      "position": [
        832,
        -160
      ],
      "typeVersion": 1.1,
      "credentials": {
        "openAiApi": {
          "id": "HyW8ouCVmeOyWpiD",
          "name": "n8n free OpenAI API credits"
        }
      },
      "notes": "定制化 Upsell 话术：主推 Easy Payment Plan (EPP) 账单分期"
    },
    {
      "parameters": {
        "jsCode": "const sessionId = $('Voice Trigger').first().json.body.session_id;\n\nlet rawText = $input.first().json.message.content;\nrawText = rawText.replace(/```json/gi, '').replace(/```/g, '').trim();\nconst extractedData = JSON.parse(rawText);\n\n// 如果大模型没提取到，强制转化为 null 传给后端\nreturn {\n  session_id: sessionId,\n  nric: extractedData.NRIC || null,\n  last_4_cc: extractedData.Credit_Card_Last_4 || null\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -64,
        -64
      ],
      "id": "21c811f8-623c-47cb-aac3-1d5f04f18ec7",
      "name": "Code in JavaScript",
      "alwaysOutputData": true,
      "retryOnFail": true,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "=={{\n  {\n    \"results\": [\n      {\n        \"toolCallId\": $('Voice Trigger').item.json.body.message.toolCalls[0].id,\n        \"result\": {\n          \"status\": $json.status,\n          \"message\": $json.message\n        }\n      }\n    ]\n  }\n}}",
        "options": {}
